# .env.example — Copy this file to .env and fill in real values before running docker compose.
# DO NOT commit the .env file to git. It is listed in .gitignore.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with real values, then:
#   docker compose -f docker-compose.yml -f Infrastructure/docker-compose.prod.yml up -d

# ─── Database Credentials ────────────────────────────────────────────────────
# H2 in-memory credentials used by all 4 Spring Boot services.
# Change these from the default "root"/"root" for any public-facing deployment.
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root

# ─── Kafka Port Configuration ─────────────────────────────────────────────────
# Internal port used within the Docker bridge network (do not change).
# External port is accessible from the host / EC2 public IP for local debugging.
KAFKA_PORT_INTERNAL=9092
KAFKA_PORT_EXTERNAL=9094

# ─── Service Ports ────────────────────────────────────────────────────────────
ORDER_SERVICE_PORT=8081
INVENTORY_SERVICE_PORT=8082
PAYMENT_SERVICE_PORT=8083
NOTIFICATION_SERVICE_PORT=8084
KAFKA_UI_PORT=8090

# ─── Downstream Service URLs (Within Docker network) ─────────────────────────
# These resolve correctly inside the Docker bridge network.
# Do not change unless you rename the service containers in docker-compose.yml.
INVENTORY_SERVICE_URL=http://inventory-service:8082
PAYMENT_SERVICE_URL=http://payment-service:8083
NOTIFICATION_SERVICE_URL=http://notification-service:8084

# ─── Third-Party API Integration (Notification service) ──────────────────────
# Replace these with real API base URLs when you integrate actual email/SMS providers.
# The notification-service currently only logs and echoes — no real calls are made.
EMAIL_SERVICE_URL=https://api.email-provider.com
SMS_SERVICE_URL=https://api.sms-provider.com
